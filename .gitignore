# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# S3 server data directory
.s3data/
bin/

dist
# The admin frontend's built SPA (internal/adminhandler/frontend/dist) is NOT
# committed: it is produced by CI (the frontend workflow) and on release, and a
# plain `go build` embeds only the placeholder. Keep just the .gitkeep so the
# go:embed directive compiles on a fresh checkout.
!/internal/adminhandler/frontend/dist/
/internal/adminhandler/frontend/dist/*
!/internal/adminhandler/frontend/dist/.gitkeep
/fs

helm/*.tgz
